        <!-- PERSONA: Category Manager -->
        <mxCell id="cm_box" value="👤 Category Manager&#xa;&#xa;• Uploads SOW / contract&#xa;• Triggers AI negotiation&#xa;• Reviews &amp; approves terms&#xa;• Provides feedback to agent" style="rounded=12;whiteSpace=wrap;html=1;fillColor=#09131b;strokeColor=#09131b;fontColor=#FFFFFF;fontSize=11;verticalAlign=top;align=center;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="80" y="100" width="230" height="130" as="geometry" />
        </mxCell>

        <!-- PERSONA: Vendor -->
        <mxCell id="vendor_box" value="👤 Vendor / Supplier&#xa;&#xa;• Views active SOW negotiations&#xa;• Chats with AI negotiation agent&#xa;• Counter-offers and agrees terms&#xa;• Receives completion notice" style="rounded=12;whiteSpace=wrap;html=1;fillColor=#F89738;strokeColor=#F89738;fontColor=#09131b;fontSize=11;verticalAlign=top;align=center;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1590" y="100" width="230" height="130" as="geometry" />
        </mxCell>

        <!-- ═══════════════════ FRONTEND LAYER ═══════════════════ -->
        <mxCell id="fe_layer" value="Frontend Layer — Next.js 15 · React 19 · TypeScript · Tailwind CSS · Deployed on Vercel" style="swimlane;startSize=32;fillColor=#FFF8F0;strokeColor=#F89738;strokeWidth=2;fontStyle=1;fontSize=12;fontColor=#09131b;" vertex="1" parent="1">
          <mxGeometry x="50" y="265" width="1800" height="210" as="geometry" />
        </mxCell>

        <mxCell id="fe_landing" value="🏠 Landing Page&#xa;&#xa;• Persona selection&#xa;  (Category Manager / Vendor)&#xa;• How it Works tab&#xa;• Benchmark criteria tab&#xa;  (P25 / P50 / P75 / P90 explained)" style="rounded=10;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#DBDBDB;strokeWidth=1.5;fontSize=10;fontColor=#09131b;verticalAlign=top;align=left;spacingLeft=6;arcSize=8;" vertex="1" parent="fe_layer">
          <mxGeometry x="25" y="45" width="220" height="145" as="geometry" />
        </mxCell>

        <mxCell id="fe_manager" value="📁 Category Manager Portal&#xa;&#xa;• Drag &amp; drop SOW upload&#xa;  (PDF / DOCX / TXT, max 10 MB)&#xa;• My Contracts table with 9 statuses&#xa;• Pending Approvals queue&#xa;• 'Send to AI Agent for Negotiation'&#xa;• Filter by status" style="rounded=10;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#09131b;strokeWidth=2;fontSize=10;fontColor=#09131b;verticalAlign=top;align=left;spacingLeft=6;arcSize=8;" vertex="1" parent="fe_layer">
          <mxGeometry x="275" y="45" width="265" height="145" as="geometry" />
        </mxCell>

        <mxCell id="fe_approval" value="✅ Contract Approval Page&#xa;&#xa;• Contract Intelligence (extraction confidence)&#xa;• Benchmark Analysis (p50/p75 comparison)&#xa;• Final Negotiated Terms&#xa;• Full Negotiation Transcript&#xa;• Decision: Approve / Re-negotiate / Offline Review&#xa;• Mandatory CM comments (agent learning)" style="rounded=10;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#09131b;strokeWidth=2;fontSize=10;fontColor=#09131b;verticalAlign=top;align=left;spacingLeft=6;arcSize=8;" vertex="1" parent="fe_layer">
          <mxGeometry x="570" y="45" width="300" height="145" as="geometry" />
        </mxCell>

        <mxCell id="fe_vendor" value="💬 Vendor Portal&#xa;&#xa;• Available SOW session picker&#xa;  (per-SOW connecting state)&#xa;• Full-width negotiation chat&#xa;• AI counter-offer tables&#xa;  (Benchmark / Delta from Benchmark cols)&#xa;• Completion &amp; approval notice" style="rounded=10;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#F89738;strokeWidth=2;fontSize=10;fontColor=#09131b;verticalAlign=top;align=left;spacingLeft=6;arcSize=8;" vertex="1" parent="fe_layer">
          <mxGeometry x="1305" y="45" width="265" height="145" as="geometry" />
        </mxCell>

        <!-- ═══════════════════ BACKEND API LAYER ═══════════════════ -->
        <mxCell id="be_layer" value="Backend API Layer — FastAPI · Python 3.12 · Uvicorn · Deployed on Railway" style="swimlane;startSize=32;fillColor=#F0F6FF;strokeColor=#4A90D9;strokeWidth=2;fontStyle=1;fontSize=12;fontColor=#09131b;" vertex="1" parent="1">
          <mxGeometry x="50" y="510" width="1800" height="185" as="geometry" />
        </mxCell>

        <mxCell id="be_upload" value="POST /api/sessions&#xa;&#xa;Upload SOW file&#xa;Extract text (PDF/DOCX/TXT)&#xa;Create session (status: uploaded)" style="rounded=8;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#4A90D9;strokeWidth=1.5;fontSize=10;fontColor=#09131b;verticalAlign=top;align=center;arcSize=6;" vertex="1" parent="be_layer">
          <mxGeometry x="25" y="45" width="185" height="120" as="geometry" />
        </mxCell>

        <mxCell id="be_trigger" value="POST /{id}/trigger&#xa;&#xa;CM sends SOW to agent&#xa;(or re-triggers re-negotiation)&#xa;Resets chat for re-neg&#xa;Status → sent_for_negotiation" style="rounded=8;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#4A90D9;strokeWidth=1.5;fontSize=10;fontColor=#09131b;verticalAlign=top;align=center;arcSize=6;" vertex="1" parent="be_layer">
          <mxGeometry x="230" y="45" width="185" height="120" as="geometry" />
        </mxCell>

        <mxCell id="be_initiate" value="POST /{id}/initiate&#xa;&#xa;Vendor connects to session&#xa;Agent runs opening turn&#xa;Injects re-neg reason if set&#xa;Status → negotiation_in_progress" style="rounded=8;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#4A90D9;strokeWidth=1.5;fontSize=10;fontColor=#09131b;verticalAlign=top;align=center;arcSize=6;" vertex="1" parent="be_layer">
          <mxGeometry x="435" y="45" width="185" height="120" as="geometry" />
        </mxCell>

        <mxCell id="be_chat" value="POST /{id}/chat&#xa;&#xa;Vendor sends message&#xa;Agent generates reply&#xa;Detects negotiation complete&#xa;Status → pending_approval" style="rounded=8;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#4A90D9;strokeWidth=1.5;fontSize=10;fontColor=#09131b;verticalAlign=top;align=center;arcSize=6;" vertex="1" parent="be_layer">
          <mxGeometry x="640" y="45" width="185" height="120" as="geometry" />
        </mxCell>

        <mxCell id="be_approval" value="POST /{id}/approval&#xa;&#xa;3 decisions: approved /&#xa;renegotiate / offline_review&#xa;Saves CM feedback for learning&#xa;Updates contract status" style="rounded=8;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#4A90D9;strokeWidth=1.5;fontSize=10;fontColor=#09131b;verticalAlign=top;align=center;arcSize=6;" vertex="1" parent="be_layer">
          <mxGeometry x="845" y="45" width="185" height="120" as="geometry" />
        </mxCell>

        <mxCell id="be_summary" value="GET /{id}/summary&#xa;&#xa;Full chat transcript&#xa;Session metadata&#xa;Approval decision&#xa;Used by approval page" style="rounded=8;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#4A90D9;strokeWidth=1.5;fontSize=10;fontColor=#09131b;verticalAlign=top;align=center;arcSize=6;" vertex="1" parent="be_layer">
          <mxGeometry x="1050" y="45" width="185" height="120" as="geometry" />
        </mxCell>

        <mxCell id="be_analysis" value="GET /{id}/analysis&#xa;&#xa;Extraction output&#xa;Benchmark comparison data&#xa;Confidence scores&#xa;Explainability for CM" style="rounded=8;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#4A90D9;strokeWidth=1.5;fontSize=10;fontColor=#09131b;verticalAlign=top;align=center;arcSize=6;" vertex="1" parent="be_layer">
          <mxGeometry x="1255" y="45" width="185" height="120" as="geometry" />
        </mxCell>

        <mxCell id="be_list" value="GET /api/sessions&#xa;&#xa;List all sessions&#xa;with status + approval&#xa;Used by both portals&#xa;Auto-refreshes every 8–10s" style="rounded=8;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#4A90D9;strokeWidth=1.5;fontSize=10;fontColor=#09131b;verticalAlign=top;align=center;arcSize=6;" vertex="1" parent="be_layer">
          <mxGeometry x="1460" y="45" width="185" height="120" as="geometry" />
        </mxCell>

        <!-- ═══════════════════ AI AGENT LAYER ═══════════════════ -->
        <mxCell id="agent_layer" value="AI Agent Layer — Single NegotiationAgent · Claude Sonnet (claude-sonnet-4-5) · Anthropic Tool Use" style="swimlane;startSize=32;fillColor=#FFF8F0;strokeColor=#F89738;strokeWidth=2;fontStyle=1;fontSize=12;fontColor=#09131b;" vertex="1" parent="1">
          <mxGeometry x="50" y="730" width="1800" height="220" as="geometry" />
        </mxCell>

        <mxCell id="agent_core" value="🤖 NegotiationAgent&#xa;&#xa;Senior commercial negotiator.&#xa;Speaks directly to vendor.&#xa;Every position backed by&#xa;internal benchmark data.&#xa;&#xa;Learns from CM feedback via&#xa;dynamic system prompt suffix.&#xa;&#xa;Re-negotiation context injected&#xa;when contract is returned by CM." style="rounded=12;whiteSpace=wrap;html=1;fillColor=#09131b;strokeColor=#09131b;fontColor=#FFFFFF;fontSize=11;verticalAlign=top;align=center;arcSize=8;" vertex="1" parent="agent_layer">
          <mxGeometry x="25" y="45" width="270" height="155" as="geometry" />
        </mxCell>

        <mxCell id="tool1" value="🔧 Tool: extract_sow_data&#xa;&#xa;Parses contract document.&#xa;Extracts: roles, hourly rates,&#xa;FTE counts, seniority levels,&#xa;payment terms, key clauses.&#xa;&#xa;Returns confidence score&#xa;(0–1) per extracted field." style="rounded=10;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#F89738;strokeWidth=2;fontSize=10;fontColor=#09131b;verticalAlign=top;align=left;spacingLeft=6;arcSize=8;" vertex="1" parent="agent_layer">
          <mxGeometry x="340" y="45" width="270" height="155" as="geometry" />
        </mxCell>

        <mxCell id="tool2" value="🔧 Tool: lookup_benchmarks&#xa;&#xa;Queries internal synthetic&#xa;benchmark database.&#xa;Returns per-role:&#xa;• p25 / p50 / p75 / p90 bands&#xa;• Market position label&#xa;• Delta from benchmark %&#xa;• Target &amp; walk-away rates&#xa;• Monthly cost exposure ($)" style="rounded=10;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#F89738;strokeWidth=2;fontSize=10;fontColor=#09131b;verticalAlign=top;align=left;spacingLeft=6;arcSize=8;" vertex="1" parent="agent_layer">
          <mxGeometry x="655" y="45" width="270" height="155" as="geometry" />
        </mxCell>

        <mxCell id="tool3" value="🔧 Tool: save_feedback&#xa;&#xa;Persists negotiation outcome.&#xa;Stores: rating, outcome type&#xa;(agreed/partial/no_deal),&#xa;what worked, what didn't,&#xa;CM comments.&#xa;&#xa;Fed into learning context&#xa;for future negotiations." style="rounded=10;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#F89738;strokeWidth=2;fontSize=10;fontColor=#09131b;verticalAlign=top;align=left;spacingLeft=6;arcSize=8;" vertex="1" parent="agent_layer">
          <mxGeometry x="970" y="45" width="270" height="155" as="geometry" />
        </mxCell>

        <mxCell id="claude_api" value="☁️ Anthropic Claude API&#xa;&#xa;Model: claude-sonnet-4-5&#xa;Max tokens: 4096&#xa;Tool use: enabled&#xa;&#xa;Called via Anthropic Python SDK.&#xa;Loops until stop_reason ≠ tool_use.&#xa;Captures tool results for&#xa;explainability panel." style="rounded=10;whiteSpace=wrap;html=1;fillColor=#7C3AED;strokeColor=#7C3AED;fontColor=#FFFFFF;fontSize=10;verticalAlign=top;align=center;arcSize=8;" vertex="1" parent="agent_layer">
          <mxGeometry x="1490" y="45" width="260" height="155" as="geometry" />
        </mxCell>

        <!-- ═══════════════════ DATA LAYER ═══════════════════ -->
        <mxCell id="data_layer" value="Data Layer — In-Memory Session Store + Synthetic Benchmark &amp; Feedback Data (data_store.py)" style="swimlane;startSize=32;fillColor=#F0FDF4;strokeColor=#16A34A;strokeWidth=2;fontStyle=1;fontSize=12;fontColor=#09131b;" vertex="1" parent="1">
          <mxGeometry x="50" y="985" width="1800" height="185" as="geometry" />
        </mxCell>

        <mxCell id="data_sessions" value="📦 Session Store&#xa;(Python dict, in-memory)&#xa;&#xa;• session_id, filename, sow_text&#xa;• Agent message history (full)&#xa;• Chat transcript (role + content)&#xa;• Status (9 possible states)&#xa;• Approval decision + CM comments&#xa;• Analysis / tool output cache&#xa;• Re-negotiate reason" style="rounded=10;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#16A34A;strokeWidth=1.5;fontSize=10;fontColor=#09131b;verticalAlign=top;align=left;spacingLeft=6;arcSize=8;" vertex="1" parent="data_layer">
          <mxGeometry x="25" y="45" width="295" height="125" as="geometry" />
        </mxCell>

        <mxCell id="data_bench" value="📊 Benchmark Data&#xa;(Synthetic, 15+ roles)&#xa;&#xa;Roles: Solution Architect, PM,&#xa;BA, DevOps, QA Lead, Data Eng,&#xa;Scrum Master, Security Eng, etc.&#xa;&#xa;Per role: p25/p50/p75/p90 ($/hr)&#xa;Payment terms benchmarks&#xa;(Net 30 preferred standard)" style="rounded=10;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#16A34A;strokeWidth=1.5;fontSize=10;fontColor=#09131b;verticalAlign=top;align=left;spacingLeft=6;arcSize=8;" vertex="1" parent="data_layer">
          <mxGeometry x="360" y="45" width="295" height="125" as="geometry" />
        </mxCell>

        <mxCell id="data_feedback" value="🧠 Feedback &amp; Learning Store&#xa;(Synthetic seed + runtime data)&#xa;&#xa;Stores per session:&#xa;• Numeric rating (1–5)&#xa;• Outcome: agreed/partial/no_deal&#xa;• What worked in negotiation&#xa;• What didn't work&#xa;• Full CM comments and reasons&#xa;• Timestamp" style="rounded=10;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#16A34A;strokeWidth=1.5;fontSize=10;fontColor=#09131b;verticalAlign=top;align=left;spacingLeft=6;arcSize=8;" vertex="1" parent="data_layer">
          <mxGeometry x="695" y="45" width="295" height="125" as="geometry" />
        </mxCell>

        <mxCell id="data_learning" value="🎓 Learning Context Engine&#xa;&#xa;Reads recent feedback history.&#xa;Builds dynamic prompt suffix&#xa;injected into every agent turn.&#xa;&#xa;Agent adapts strategy based on:&#xa;• Past approval outcomes&#xa;• Rejected negotiation patterns&#xa;• CM re-negotiate instructions&#xa;• Successful rate positions" style="rounded=10;whiteSpace=wrap;html=1;fillColor=#FFF8F0;strokeColor=#F89738;strokeWidth=2;fontSize=10;fontColor=#09131b;verticalAlign=top;align=left;spacingLeft=6;arcSize=8;" vertex="1" parent="data_layer">
          <mxGeometry x="1030" y="45" width="295" height="125" as="geometry" />
        </mxCell>

